# ===========================================
# UAT (User Acceptance Testing) — legacy
# ===========================================

# Python
uat/__pycache__/
uat/*.py[cod]
uat/*$py.class
uat/.Python
uat/venv/
uat/env/
uat/.venv/
uat/.deps_installed

# UAT Screenshots (can be large, regenerated)
uat/screenshots/*.png
uat/screenshots/*.jpg
uat/screenshots/*.jpeg

# UAT Reports (generated output)
uat/reports/*.json
uat/reports/*.md
uat/reports/*.html

# Keep directory structure
!uat/screenshots/.gitkeep
!uat/reports/.gitkeep

# Browser state (contains session cookies - sensitive)
uat/browser_state/

# Playwright
uat/test-results/
uat/playwright-report/
uat/.playwright/

# Browser-Use
uat/.browser-use/
uat/browser_data/

# UAT local config
uat/.env.local
uat/config.local.yaml

# ===========================================
# UI Testing (uitest/) — multi-app visual testing
# ===========================================

# Python
uitest/__pycache__/
uitest/*.py[cod]
uitest/*$py.class
uitest/.Python
uitest/venv/
uitest/env/
uitest/.venv/
uitest/.deps_installed

# Screenshots (can be large, regenerated)
uitest/screenshots/*.png
uitest/screenshots/*.jpg
uitest/screenshots/*.jpeg

# Reports (generated output)
uitest/reports/*.json
uitest/reports/*.md
uitest/reports/*.html

# Content (extracted markdown)
uitest/content/*.md

# Keep directory structure
!uitest/screenshots/.gitkeep
!uitest/reports/.gitkeep
!uitest/content/.gitkeep

# Browser state (contains session cookies - sensitive)
uitest/browser_state/

# Playwright
uitest/test-results/
uitest/playwright-report/
uitest/.playwright/

# Browser-Use
uitest/.browser-use/
uitest/browser_data/

# UI test local config
uitest/.env.local
uitest/config.local.yaml

# Claude Code local settings (contains server names, permissions, SSH paths)
.claude/settings.local.json
